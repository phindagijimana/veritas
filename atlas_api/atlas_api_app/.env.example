ATLAS_APP_NAME=Veritas Atlas API
ATLAS_API_PREFIX=/api/v1
ATLAS_ENV=dev
ATLAS_AUTH_MODE=hybrid
ATLAS_INTERNAL_API_KEY=test-internal-key
ATLAS_JWT_ISSUER=https://issuer.example.com/
ATLAS_JWT_AUDIENCE=veritas-atlas
ATLAS_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
ATLAS_DEV_BEARER_SECRET=local-dev-secret

# PostgreSQL (default matches docker-compose.yml in this directory)
ATLAS_DATABASE_URL=postgresql+psycopg2://atlas:atlas@127.0.0.1:5432/atlas_dev
ATLAS_DATABASE_AUTO_CREATE_SCHEMA=false

# Redis + Celery (optional; matches docker-compose redis service)
# ATLAS_REDIS_URL=redis://127.0.0.1:6379/0
# MinIO S3 API (optional; create bucket "atlas" in console http://127.0.0.1:9001 )
# ATLAS_S3_ENDPOINT_URL=http://127.0.0.1:9000
# ATLAS_S3_ACCESS_KEY=atlasminio
# ATLAS_S3_SECRET_KEY=atlasminio_secret
# ATLAS_S3_BUCKET=atlas

PENNSIEVE_API_TOKEN=
PENNSIEVE_API_SECRET=
PENNSIEVE_ORGANIZATION_ID=

# Veritas service auth (must match Veritas ATLAS_API_CLIENT_SECRET when using live integration)
# ATLAS_VERITAS_CLIENT_SECRET=
# Production: set ATLAS_REQUIRE_VERITAS_CLIENT_SECRET=true to fail boot if secret is missing
# ATLAS_REQUIRE_VERITAS_CLIENT_SECRET=false
