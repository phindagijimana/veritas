# Copy to `.env` in this directory (backend/). Pydantic loads `.env` from the process working directory.
# APP_ENV: development | staging | production (production triggers startup validation in app.main)
#
# Quick start without Docker (SQLite, no Redis required):  cp env.local.sqlite.example .env

# --- Core API ---
APP_NAME="Veritas API"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
# Default matches docker-compose.yml (Postgres on host port 5433 to avoid clashing with other stacks).
DATABASE_URL=postgresql+psycopg://veritas:veritas@127.0.0.1:5433/veritas_dev
# Dev: false and run `alembic upgrade head` after `docker compose up -d`. Production: false.
DATABASE_AUTO_CREATE_SCHEMA=false
# Dev: load demo rows from app.main.seed_data. Must be false in production.
SEED_DEMO_DATA_ON_STARTUP=true
REDIS_URL=redis://127.0.0.1:6380/0
# Celery: set true in prod when running `scripts/run_celery_worker.sh` (or `./platform worker`) for async sweeps/reports.
JOB_QUEUE_ENABLED=false
RQ_QUEUE_NAME=ai-biomarkers
RQ_JOB_TIMEOUT_SECONDS=3600
RQ_RETRY_MAX=2
RQ_RETRY_INTERVALS=30,120,300
RQ_FAILED_JOB_TTL_SECONDS=604800

# JSON array (pydantic-settings). Include both hostnames if you use either in the browser.
ALLOWED_ORIGINS=["http://localhost:7000","http://127.0.0.1:7000"]
# Optional: restrict Host header (comma-separated). Empty = disabled. Use behind reverse proxy in prod.
# TRUSTED_HOSTS=api.localhost,localhost
TRUSTED_HOSTS=

# --- HPC / Slurm ---
# slurm (default): job submit uses SSH to the active HPC connection (mkdir, sbatch). Requires /hpc/connect first.
# mock: simulated Slurm only — use for automated tests or API development without a cluster (see tests/conftest.py).
HPC_MODE=slurm
# Slurm only: optional startup SSH check to active HPC connection.
HPC_VALIDATE_ON_STARTUP=false
# Optional lines injected into sbatch after #SBATCH headers (cluster-specific modules).
# HPC_JOB_PROLOGUE_SH=module load apptainer
HPC_JOB_PROLOGUE_SH=
SSH_CONNECT_TIMEOUT_SECONDS=8
SSH_STRICT_HOST_KEY_CHECKING=false
SLURM_REMOTE_WORKDIR=~/veritas/jobs
SLURM_POLL_COMMAND=squeue -h -j {job_id} -o %T
SLURM_CANCEL_COMMAND=scancel {job_id}
SCHEDULER_SYNC_ENABLED=true
# Slurm job scripts: docker | apptainer | singularity (OCI as docker:// on HPC). Prefer apptainer on Slurm — Docker/Podman often breaks without /run/user/<uid> on compute nodes.
# RUNTIME_ENGINE=apptainer
RUNTIME_ENGINE=docker
JOB_MONITOR_INTERVAL_SECONDS=30

# --- Artifacts & dataset paths ---
# STORAGE_BACKEND=local uses ARTIFACT_ROOT_DIR; STORAGE_BACKEND=s3 uses MinIO/S3 (create bucket first).
STORAGE_BACKEND=local
ARTIFACT_ROOT_DIR=./var/veritas_artifacts
PUBLIC_ARTIFACT_BASE_URL=http://localhost:6000/static
# S3 (MinIO example: endpoint http://127.0.0.1:9002, console http://127.0.0.1:9003 — see docker-compose.yml)
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=veritas
# S3_REGION=us-east-1
DATASET_ROOT_DIR=./sample_data
DATASET_STAGING_ROOT=/scratch/veritas/staging
# BIDS root for IDEAS when jobs omit staged_dataset_path (fallback before $VERITAS_STAGED_DATASET_PATH). Slurm/MELD scripts.
# MELD_IDEAS_DEFAULT_STAGING_PATH=/path/to/bids_IDEAS
# Absolute path on Slurm compute nodes: directory containing license.txt and meld_license.txt (also embedded in MELD runtime when set).
# MELD_LICENSE_HOST_DIR=/path/to/licenses
PROMETHEUS_ENABLED=true

# --- Pipeline image validation ---
IMAGE_VALIDATION_MODE=local
IMAGE_VALIDATION_TIMEOUT_SECONDS=60

# --- Auth (JWT via python-jose when AUTH_ENABLED=true) ---
AUTH_ENABLED=false
AUTH_MODE=local
AUTH_SECRET_KEY=change-me
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_DEFAULT_DEV_EMAIL=dev@veritas.local
AUTH_DEFAULT_DEV_ROLE=admin

# --- Atlas / Pennsieve (replace example URLs and secrets for real integration) ---
# Local dev with ./scripts/dev-stack.sh + ./api start (Atlas on 8000): use /api/v1 suffix.
# ATLAS_API_BASE_URL=http://127.0.0.1:8000/api/v1
ATLAS_API_BASE_URL=https://atlas.example.org/api/v1
ATLAS_API_CLIENT_ID=veritas
# Must match Atlas ATLAS_VERITAS_CLIENT_SECRET when ATLAS_INTEGRATION_MODE=live
ATLAS_API_CLIENT_SECRET=change-me
ATLAS_API_TIMEOUT_SECONDS=20
ATLAS_DATASET_MODE=atlas
ATLAS_STAGE_SCRIPT_NAME=stage_dataset.sh
ATLAS_STAGE_ENV_FILENAME=atlas_stage.env
ATLAS_MONITOR_POLL_SECONDS=30
# mock = MockAtlasClient (no Atlas HTTP). live = HTTP client to ATLAS_API_BASE_URL.
ATLAS_INTEGRATION_MODE=mock
PENNSIEVE_API_TOKEN=
PENNSIEVE_MANIFEST_PATH_TEMPLATE=/datasets/{dataset_id}/manifest
PENNSIEVE_BASE_URL=https://api.pennsieve.io
PENNSIEVE_TIMEOUT_SECONDS=30

# --- HTTP limits (Phase 8) ---
MAX_REQUEST_BODY_BYTES=52428800
RATE_LIMIT_TRUST_PROXY_HEADERS=false
# Per-endpoint POST limits (limits.parse format). Empty = only global SlowAPI default applies.
AUTH_LOGIN_RATE_LIMIT=30/minute
AUTH_REGISTER_RATE_LIMIT=15/hour
