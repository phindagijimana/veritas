# Copy to `.env` in this directory:  cp env.local.sqlite.example .env
# SQLite dev — no Docker/Postgres/Redis required. From repo root: ./platform start

APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./var/veritas_dev.sqlite
DATABASE_AUTO_CREATE_SCHEMA=true
SEED_DEMO_DATA_ON_STARTUP=true
JOB_QUEUE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6380/0
ALLOWED_ORIGINS=["http://localhost:7000","http://127.0.0.1:7000"]
HPC_MODE=mock
# Slurm/HPC: apptainer or singularity for docker:// images (see RUNTIME_ENGINE in .env.example)
# RUNTIME_ENGINE=docker
STORAGE_BACKEND=local
ATLAS_INTEGRATION_MODE=mock
# Local IDEAS BIDS extract (MELD job fallback path). Example: .../bids_IDEAS_extract/bids_IDEAS
# MELD_IDEAS_DEFAULT_STAGING_PATH=/path/to/bids_IDEAS
VERITAS_HOST=0.0.0.0
VERITAS_PORT=6000
