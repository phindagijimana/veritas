# Production template — copy to a secrets manager / CI inject; never commit real secrets.
# Align with validate_production_settings() in app/core/config.py (APP_ENV=production).

APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

# Managed Postgres (TLS URL recommended)
DATABASE_URL=postgresql+psycopg://veritas:REPLACE_ME@db.internal:5432/veritas_prod
DATABASE_AUTO_CREATE_SCHEMA=false
SEED_DEMO_DATA_ON_STARTUP=false

REDIS_URL=redis://redis.internal:6379/0
JOB_QUEUE_ENABLED=true
# Periodic /jobs/monitor/sweep cadence (Celery beat task — fires every N seconds when
# you run `celery -A app.celery_app.celery_app beat` alongside the worker).
JOB_MONITOR_INTERVAL_SECONDS=30

# HTTPS origins of the Veritas UI only (no wildcard)
ALLOWED_ORIGINS=https://veritas.example.com
# Optional: Host header allowlist (comma-separated). Set behind reverse proxy / ingress.
# TRUSTED_HOSTS=api.veritas.example.com,localhost

AUTH_ENABLED=true
AUTH_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

ATLAS_API_BASE_URL=https://atlas.yourorg.org/api/v1
ATLAS_API_CLIENT_SECRET=REPLACE_MATCHING_ATLAS_VERITAS_SECRET
ATLAS_INTEGRATION_MODE=live

HPC_MODE=slurm
SSH_STRICT_HOST_KEY_CHECKING=true
IMAGE_VALIDATION_MODE=registry

PUBLIC_ARTIFACT_BASE_URL=https://api.veritas.example.com/static
ARTIFACT_ROOT_DIR=/data/veritas_artifacts
RATE_LIMIT_TRUST_PROXY_HEADERS=true

# Celery worker runs separately with same env
# MELD / staging paths for your cluster
# MELD_LICENSE_HOST_DIR=/ood/licenses/meld

# ─── Email notifications (optional, OFF by default) ─────────────────────────
# In-app bell notifications work without these; turning EMAIL_ENABLED on adds
# a best-effort SMTP fan-out for kinds like report.ready. SMTP failures never
# block the API request that triggered the notification.
# EMAIL_ENABLED=true
# EMAIL_SMTP_HOST=smtp.yourorg.org
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USERNAME=veritas@yourorg.org
# EMAIL_SMTP_PASSWORD=REPLACE_ME
# EMAIL_SMTP_USE_TLS=true                  # STARTTLS for ports 25/587
# EMAIL_SMTP_USE_SSL=false                 # set true (and PORT=465) for SMTPS
# EMAIL_SMTP_TIMEOUT_SECONDS=15
# EMAIL_FROM=Veritas <noreply@yourorg.org>
# EMAIL_APP_BASE_URL=https://veritas.example.com   # used to build "Open in Veritas" links

# ─── Operations ─────────────────────────────────────────────────────────────
# Reference: docs/VERITAS_OPS_RUNBOOK.md (backup/restore/upgrade/rollback/incidents)
# Reference: docs/grafana/veritas-overview.json (importable Grafana dashboard)
# Reference: scripts/backup_postgres.sh (nightly Postgres dump + retention)
# Reference: scripts/audit_retention.sh (archive + prune audit_events older than N days)
# Reference: scripts/loadtest_veritas.py (locust scenario for capacity baselines)
#
# Recommended monitoring scrape: GET /metrics (Prometheus exposition format).
# Recommended alert rules:
#   * absent(up{job="veritas-api"}) > 2m            — process is down
#   * rate(veritas_http_requests_total{status=~"5.."}[5m]) > 0.05  — 5xx surge
#   * histogram_quantile(0.95, rate(veritas_http_request_duration_seconds_bucket[5m])) > 1  — slow
#   * up{job="postgres"} == 0                       — DB down
#
# First-admin bootstrap on a fresh production DB:
#   The UI's LoginGate detects an empty admin table and offers a one-shot
#   "Set up the first admin" form. If you'd rather provision from the shell:
#     python -m app.cli users create-admin --email you@example.org
#   (See docs/VERITAS_PRODUCTION.md "First-admin bootstrap (production)".)
