# Production template — copy to a secrets manager / CI inject; never commit real secrets.
# Align with validate_production_settings() in app/core/config.py (APP_ENV=production).

APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

# Managed Postgres (TLS URL recommended)
DATABASE_URL=postgresql+psycopg://veritas:REPLACE_ME@db.internal:5432/veritas_prod
DATABASE_AUTO_CREATE_SCHEMA=false
SEED_DEMO_DATA_ON_STARTUP=false

REDIS_URL=redis://redis.internal:6379/0
JOB_QUEUE_ENABLED=true

# HTTPS origins of the Veritas UI only (no wildcard)
ALLOWED_ORIGINS=https://veritas.example.com
# Optional: Host header allowlist (comma-separated). Set behind reverse proxy / ingress.
# TRUSTED_HOSTS=api.veritas.example.com,localhost

AUTH_ENABLED=true
AUTH_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

ATLAS_API_BASE_URL=https://atlas.yourorg.org/api/v1
ATLAS_API_CLIENT_SECRET=REPLACE_MATCHING_ATLAS_VERITAS_SECRET
ATLAS_INTEGRATION_MODE=live

HPC_MODE=slurm
SSH_STRICT_HOST_KEY_CHECKING=true
IMAGE_VALIDATION_MODE=registry

PUBLIC_ARTIFACT_BASE_URL=https://api.veritas.example.com/static
ARTIFACT_ROOT_DIR=/data/veritas_artifacts
RATE_LIMIT_TRUST_PROXY_HEADERS=true

# Celery worker runs separately with same env
# MELD / staging paths for your cluster
# MELD_LICENSE_HOST_DIR=/ood/licenses/meld
