# Production-oriented template. When APP_ENV=production, the API refuses to start if:
# - DEBUG is not false
# - DATABASE_URL still points at SQLite
# - DATABASE_AUTO_CREATE_SCHEMA or SEED_DEMO_DATA_ON_STARTUP is still true (use Alembic + no demo seed)
# - AUTH_ENABLED=true but AUTH_SECRET_KEY is empty or a known placeholder
# - ATLAS_API_CLIENT_SECRET is empty or a known placeholder
# - HPC_MODE=slurm but SSH_STRICT_HOST_KEY_CHECKING is not true
#
# Generate strong secrets, e.g. `openssl rand -hex 32`, and inject via your secret manager or orchestrator.

APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
APP_NAME="Veritas API"

DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/ai_biomarkers
DATABASE_AUTO_CREATE_SCHEMA=false
SEED_DEMO_DATA_ON_STARTUP=false
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_ENABLED=true
RQ_QUEUE_NAME=ai-biomarkers
RQ_JOB_TIMEOUT_SECONDS=3600
RQ_RETRY_MAX=2
RQ_RETRY_INTERVALS=30,120,300
RQ_FAILED_JOB_TTL_SECONDS=604800

# Set to your real frontend / gateway origins (comma-separated)
ALLOWED_ORIGINS=https://veritas.example.org

HPC_MODE=slurm
HPC_VALIDATE_ON_STARTUP=false
# HPC_JOB_PROLOGUE_SH=module load apptainer
HPC_JOB_PROLOGUE_SH=
SSH_CONNECT_TIMEOUT_SECONDS=8
SSH_STRICT_HOST_KEY_CHECKING=true
SLURM_REMOTE_WORKDIR=~/veritas/jobs
SLURM_POLL_COMMAND=squeue -h -j {job_id} -o %T
SLURM_CANCEL_COMMAND=scancel {job_id}
SCHEDULER_SYNC_ENABLED=true
RUNTIME_ENGINE=apptainer
JOB_MONITOR_INTERVAL_SECONDS=30

ARTIFACT_ROOT_DIR=/app/var/veritas_artifacts
DATASET_ROOT_DIR=/app/sample_data
DATASET_STAGING_ROOT=/var/veritas/staging
PUBLIC_ARTIFACT_BASE_URL=https://veritas.example.org/api/static
PROMETHEUS_ENABLED=true

IMAGE_VALIDATION_MODE=local
IMAGE_VALIDATION_TIMEOUT_SECONDS=60

AUTH_ENABLED=false
AUTH_MODE=local
AUTH_SECRET_KEY=replace-with-openssl-rand-hex-32
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_DEFAULT_DEV_EMAIL=dev@veritas.local
AUTH_DEFAULT_DEV_ROLE=admin

ATLAS_API_BASE_URL=https://atlas.your-org.example/api/v1
ATLAS_API_CLIENT_ID=veritas
ATLAS_API_CLIENT_SECRET=replace-with-atlas-issued-secret
ATLAS_API_TIMEOUT_SECONDS=20
ATLAS_DATASET_MODE=atlas
ATLAS_STAGE_SCRIPT_NAME=stage_dataset.sh
ATLAS_STAGE_ENV_FILENAME=atlas_stage.env
ATLAS_MONITOR_POLL_SECONDS=30
ATLAS_INTEGRATION_MODE=mock
PENNSIEVE_API_TOKEN=
PENNSIEVE_MANIFEST_PATH_TEMPLATE=/datasets/{dataset_id}/manifest
PENNSIEVE_BASE_URL=https://api.pennsieve.io
PENNSIEVE_TIMEOUT_SECONDS=30

MAX_REQUEST_BODY_BYTES=52428800
RATE_LIMIT_TRUST_PROXY_HEADERS=true
AUTH_LOGIN_RATE_LIMIT=30/minute
AUTH_REGISTER_RATE_LIMIT=15/hour
