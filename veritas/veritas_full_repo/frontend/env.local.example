# Copy to .env.local:  cp env.local.example .env.local
# Relative path: Vite proxies /api, /health, /ready to the Veritas API (default http://127.0.0.1:6000). UI: http://127.0.0.1:7000
VITE_VERITAS_API_BASE_URL=/api/v1

# Optional — hot reload WebSocket (off by default; remote browsers often hang if HMR cannot connect).
# VITE_ENABLE_HMR=1

# Optional — pre-fill Veritas admin → HPC connect form only (local machine; do not commit .env.local).
# VITE_HPC_DEFAULT_HOSTNAME=login.example.org
# VITE_HPC_DEFAULT_USERNAME=you
# VITE_HPC_DEFAULT_PORT=22
# VITE_HPC_DEFAULT_KEY_PATH=~/.ssh/id_ed25519
# VITE_HPC_DEFAULT_NOTES=
